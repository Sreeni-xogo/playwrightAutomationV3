# =============================================================================
# XOGO Manager E2E — Environment Configuration
# =============================================================================

# Base URL for the target environment (pipeline-injected via Azure DevOps token replacement)
URL=#{https://url-to-xogo.manager}#

# =============================================================================
# Account Tier
# Controls which credentials are used and which tier-conditional assertions run.
# Valid values: free | pro | enterprise
# Default (when unset): pro — safe for CI pipelines, no change to existing behaviour.
# =============================================================================
ACCOUNT_TIER=pro

# =============================================================================
# Pro Tier Credentials
# Used when ACCOUNT_TIER=pro (or when ACCOUNT_TIER is unset — pipeline default).
# PRO_EMAIL / PRO_PASSWORD take precedence; EMAIL / PASSWORD act as fallback
# so existing pipelines that only set EMAIL + PASSWORD continue to work unchanged.
# =============================================================================
EMAIL=#{email@email.com}#
PASSWORD=#{password}#

PRO_EMAIL=#{pro-account@email.com}#
PRO_PASSWORD=#{password}#

# =============================================================================
# Free Tier Credentials (local testing only — never injected by pipeline)
# Set ACCOUNT_TIER=free locally to run tests against a Free-tier account.
# =============================================================================
FREE_EMAIL=#{free-account@email.com}#
FREE_PASSWORD=#{password}#

# =============================================================================
# Enterprise Tier Credentials (local testing only — never injected by pipeline)
# Set ACCOUNT_TIER=enterprise locally to run tests against an Enterprise account.
# Falls back to EMAIL / PASSWORD if ENTERPRISE_EMAIL is not set.
# =============================================================================
ENTERPRISE_EMAIL=#{enterprise-account@email.com}#
ENTERPRISE_PASSWORD=#{password}#
